# =============================================================================
# Baul — Production Environment Configuration
# =============================================================================
# Edit this file with your API keys, then:
#   sudo systemctl restart baul
# =============================================================================
# Get free API keys at:
#   OpenCode Zen: https://opencode.ai/zen  (FREE, recommended)
#   Groq:         https://console.groq.com (FREE, fast Llama 3)
#   Gemini:       https://aistudio.google.com (FREE tier for audio)
# =============================================================================

# --- LLM Backend (tried in order: OpenCode Zen -> Groq -> Gemini) ---

# Option A: OpenCode Zen (FREE, no key needed for free tier)
# Uses open-source models. Recommended default.
OPENCODE_API_KEY=
OPENCODE_MODEL=deepseek-v4-flash-free

# Option B: Groq (FREE, very fast)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Option C: Google Gemini (for audio transcription + chat fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Option D: Ollama (100% local, requires Ollama installed on this machine)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2:3b

# --- Paths ---
BRAIN_PATH=/opt/baul/brain

# --- Agent Intervals (seconds) ---
CONNECTOR_INTERVAL=300
EVOLVER_INTERVAL=600
CONNECTOR_THRESHOLD=0.60
